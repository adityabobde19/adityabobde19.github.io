<!DOCTYPE html>
<html lang="en">
  <!-- Head -->
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if page.title %}{{ page.title }} - {% endif %}{{ site.title }}</title>
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/jpswalsh/academicons@1/css/academicons.min.css">
    <style>
      /* ── Base ── */
      :root {
        --bg:       #f4f4f4;
        --surface:  #ffffff;
        --text:     #222222;
        --muted:    #555555;
        --link:     #0055cc;
        --border:   #dddddd;
        --shadow:   rgba(0,0,0,0.10);
      }
      body.dark {
        --bg:       #1a1a1a;
        --surface:  #242424;
        --text:     #e0e0e0;
        --muted:    #aaaaaa;
        --link:     #6ab0f5;
        --border:   #444444;
        --shadow:   rgba(0,0,0,0.40);
      }
      *, *::before, *::after { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.7;
        color: var(--text);
        background: var(--bg);
        max-width: 860px;
        margin: 0 auto;
        padding: 24px 28px;
        transition: background 0.3s, color 0.3s;
      }
      a { color: var(--link); }
      h1, h2, h3 { color: var(--text); }
      /* ── Header ── */
      .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid var(--border);
        padding-bottom: 16px;
        margin-bottom: 36px;
      }
      .header h1 { margin: 0; font-size: 1.6rem; }
      .nav {
        list-style: none;
        padding: 0; margin: 0;
        display: flex;
        gap: 20px;
      }
      .nav a { text-decoration: none; color: var(--link); font-weight: 500; }
      /* ── Dark mode toggle ── */
      #theme-toggle {
        background: none;
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 5px 12px;
        cursor: pointer;
        font-size: 1rem;
        color: var(--text);
        transition: background 0.2s;
        white-space: nowrap;
      }
      #theme-toggle:hover { background: var(--border); }
      /* ── Profile photo ── */
      .profile-float-img {
        float: right;
        width: 175px;
        height: 175px;
        object-fit: cover;
        border-radius: 50%;
        margin: 4px 0 1.5em 2em;
        box-shadow: 0 4px 12px var(--shadow);
      }
      /* ── Contact links ── */
      .contact-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5em 1.4em;
        padding: 0;
        margin: 0.5em 0 1.5em;
      }
      .contact-links a {
        text-decoration: none;
        color: var(--link);
        display: inline-flex;
        align-items: center;
        gap: 0.3em;
        font-size: 0.95rem;
      }
      .contact-links a:hover { text-decoration: underline; }
      /* ── Scrollable news ── */
      .news-scroll {
        max-height: 280px;
        overflow-y: auto;
        padding-left: 1.2em;
        margin: 0;
        color: var(--text);
      }
      .news-scroll li { margin-bottom: 0.5em; }
      /* ── Footer ── */
      .footer {
        text-align: center;
        margin-top: 48px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
        color: var(--muted);
        font-size: 0.88em;
      }
      /* ── Clearfix ── */
      .clearfix::after { content: ""; display: table; clear: both; }
    </style>
  </head>

  <!-- Body -->
  <body>
    <header class="header">
      <div style="display:flex; align-items:center; gap:24px;">
        <h1>{{ site.title }}</h1>
      </div>
      <button id="theme-toggle" aria-label="Toggle dark mode">🌙 Dark</button>
    </header>

    <main>
      {{ content }}
    </main>

    <footer class="footer">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ site.title }}. Last updated: {{ 'now' | date: '%B %d, %Y' }}.</p>
    </footer>

    <script>
      const btn = document.getElementById('theme-toggle');
      const saved = localStorage.getItem('theme');
      if (saved === 'dark') { document.body.classList.add('dark'); btn.textContent = '☀️ Light'; }
      btn.addEventListener('click', () => {
        const isDark = document.body.classList.toggle('dark');
        btn.textContent = isDark ? '☀️ Light' : '🌙 Dark';
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
