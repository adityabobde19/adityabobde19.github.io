<!DOCTYPE html>
<html lang="en">
  <!-- Head -->
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if page.title %}{{ page.title }} - {% endif %}{{ site.title }}</title>
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/jpswalsh/academicons@1/css/academicons.min.css">
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        line-height: 1.6;
        color: #333;
        max-width: 800px;
        margin: 0 auto;
        padding: 20px;
      }
      .header {
        text-align: center;
        border-bottom: 1px solid #eee;
        padding-bottom: 20px;
        margin-bottom: 40px;
      }
      .nav {
        list-style: none;
        padding: 0;
        display: flex;
        justify-content: center;
        gap: 20px;
      }
      .nav a {
        text-decoration: none;
        color: #0066cc;
      }
      .footer {
        text-align: center;
        margin-top: 40px;
        padding-top: 20px;
        border-top: 1px solid #eee;
        color: #666;
        font-size: 0.9em;
      }
      a {
        color: #0066cc;
      }
      h1, h2, h3 {
        color: #222;
      }
      /* Profile photo */
      .profile-float-img {
        float: right;
        width: 180px;
        height: 180px;
        object-fit: cover;
        border-radius: 50%;
        margin: 0 0 1.5em 2em;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
      }
      /* Contact links */
      .contact-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5em 1.2em;
        list-style: none;
        padding: 0;
      }
      .contact-links a {
        text-decoration: none;
        color: #0066cc;
        display: flex;
        align-items: center;
        gap: 0.3em;
      }
      .contact-links a:hover { text-decoration: underline; }
      /* Scrollable news list */
      .news-scroll {
        max-height: 280px;
        overflow-y: auto;
        padding-left: 1.2em;
        margin: 0;
      }
      .news-scroll li { margin-bottom: 0.5em; }
      /* Clear float after bio */
      .clearfix::after { content: ""; display: table; clear: both; }
    </style>
  </head>

  <!-- Body -->
  <body>
    <header class="header">
      <h1>{{ site.title }}</h1>
      <nav>
        <ul class="nav">
          <li><a href="/">About</a></li>
          <li><a href="/research.html">Research</a></li>
        </ul>
      </nav>
    </header>

    <main>
      {{ content }}
    </main>

    <footer class="footer">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ site.title }}. Last updated: {{ 'now' | date: '%B %d, %Y' }}.</p>
    </footer>
  </body>
</html>
